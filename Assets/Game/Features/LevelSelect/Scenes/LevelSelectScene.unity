  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LevelSelectSceneController
  panelRoot: {fileID: 2078824132}
  dividerImage: {fileID: 0}
  suburbanCard:
    name: Suburban
    titleLocalizationKey: 
    root: {fileID: 1756873977}
    title: {fileID: 1030400446}
    mapSprite: {fileID: 21300000, guid: 386835fc166281845b7274aaaf838471, type: 3}
    placeholderColor: {r: 0.19215687, g: 0.3254902, b: 0.40392157, a: 1}
    levels:
    - Training Map
    - Map 1
    - Map 2
    levelDefinitions:
    - buttonName: LevelButton_01
      levelId: training_map
      levelName: Training Map
      levelNameLocalizationKey: 
      description: A guided training map used for onboarding and control familiarization.
      descriptionLocalizationKey: 
      objective: Deploy into the training map and complete the tutorial scenario.
      objectiveLocalizationKey: 
      difficulty: Optional
      difficultyLocalizationKey: 
      caseId: 
      targetSceneName: 
      scenarioResourcePath: 
      scenarioDefinitions:
      - scenarioId: training_map_tutorial
        displayName: Tutorial
        caseId: TR-TU-01
        targetSceneName: Tutorial
        scenarioResourcePath: 
    - buttonName: LevelButton_02
      levelId: suburban_map_01
      levelName: Map 1
      levelNameLocalizationKey: 
      description: A suburban residential map with multiple possible incidents. The
        exact scenario will only be revealed after deployment.
      descriptionLocalizationKey: 
      objective: Deploy to the map and respond to the randomly assigned scenario.
      objectiveLocalizationKey: 
      difficulty: Normal
      difficultyLocalizationKey: 
      caseId: 
      targetSceneName: 
      scenarioResourcePath: 
      scenarioDefinitions:
      - scenarioId: suburban_map_01_kitchen_fire
        displayName: Kitchen Fire
        caseId: SH-HK-01
