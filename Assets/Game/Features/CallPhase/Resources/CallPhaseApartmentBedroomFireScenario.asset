  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f14c3d1b58a44b9a8d668ed8888e3fb4, type: 3}
  m_Name: CallPhaseApartmentBedroomFireScenario
  m_EditorClassIdentifier: 
  scenarioId: apartment_bedroom_fire
  displayName: Apartment Bedroom Fire
  category: Apartment Fire
  description: A 3rd-floor apartment bedroom fire with an elderly neighbor at risk and the caller trapped on their balcony.
  initialTranscriptLines:
  - lineId: intro_operator_open
    speaker: 0
    text: 911, where is your emergency?
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_caller_open
    speaker: 1
    text: There's a huge fire in my apartment!
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_operator_fire_location
    speaker: 0
    text: Where is the fire right now?
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_caller_fire_location
    speaker: 1
    text: It's in the bedroom on the 3rd floor!
    isExtractable: 1
    startsAsActiveChunk: 1
    isConfirmationLine: 0
    extractableSpans:
    - displayText: bedroom on the 3rd floor
      normalizedValue: Bedroom (3rd Floor)
      targetFieldId: fire_location
      infoType: FireLocation
      exactSelection: 1
      hasExtraContext: 0
  followUpSteps:
  - stepId: collect_address
    stepType: 0
    triggerFieldId: fire_location
    triggerValue: Bedroom (3rd Floor)
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_address
      speaker: 0
      text: What is the address?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_address
      speaker: 1
      text: It's 404 River Road, Apartment 3B!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: 404 River Road, Apartment 3B
        normalizedValue: 404 River Road, Apt 3B
        targetFieldId: Address
        infoType: Address
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_occupant_risk
    stepType: 0
    triggerFieldId: Address
    triggerValue: 404 River Road, Apt 3B
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_occupant_risk
      speaker: 0
      text: Is anyone still inside the apartment or on your floor?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_occupant_risk
      speaker: 1
      text: My elderly neighbor is trapped across the hall, he can't use the stairs!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: elderly neighbor is trapped
        normalizedValue: Elderly neighbor trapped
        targetFieldId: OccupantRisk
        infoType: OccupantRisk
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_hazard
    stepType: 0
    triggerFieldId: OccupantRisk
    triggerValue: Elderly neighbor trapped
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_hazard
      speaker: 0
      text: Do you know how it started? Are there any electrical or gas hazards?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_hazard
      speaker: 1
      text: It sparked from the electrical space heater and caught the curtains!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: electrical space heater
        normalizedValue: Electrical space heater
        targetFieldId: hazard
        infoType: Hazard
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_spread_status
    stepType: 0
    triggerFieldId: hazard
    triggerValue: Electrical space heater
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_spread_status
      speaker: 0
      text: Is the fire spreading out of the bedroom?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_spread_status
      speaker: 1
      text: Yes, there's black smoke spreading to the hallway!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: spreading to the hallway
        normalizedValue: Spreading to hallway
        targetFieldId: SpreadStatus
        infoType: SpreadStatus
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_caller_safety
    stepType: 0
    triggerFieldId: SpreadStatus
    triggerValue: Spreading to hallway
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_caller_safety
      speaker: 0
      text: Are you somewhere safe right now? Can you evacuate?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_caller_safety
      speaker: 1
      text: No, I can't reach the door! I'm trapped on my balcony!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: trapped on my balcony
        normalizedValue: Trapped on balcony
        targetFieldId: CallerSafety
        infoType: CallerSafety
        exactSelection: 1
        hasExtraContext: 0
  - stepId: confirm_address
    stepType: 1
    triggerFieldId: CallerSafety
    triggerValue: Trapped on balcony
    confirmationFieldId: Address
    expectedConfirmedValue: 404 River Road, Apt 3B
    operatorLine:
      lineId: confirm_address_operator
      speaker: 0
      text: Let me confirm, you are at 404 River Road, Apartment 3B?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 1
      extractableSpans: []
    callerLine:
      lineId: confirm_address_caller
      speaker: 1
      text: Yes, exactly! Please hurry!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 1
      extractableSpans:
      - displayText: Yes, exactly!
        normalizedValue: 404 River Road, Apt 3B
        targetFieldId: Address
        infoType: Address
        exactSelection: 1
        hasExtraContext: 0
  - stepId: confirm_caller_safety
    stepType: 1
    triggerFieldId: Address
    triggerValue: 404 River Road, Apt 3B
    confirmationFieldId: CallerSafety
    expectedConfirmedValue: Trapped on balcony
    operatorLine:
      lineId: confirm_safety_operator
      speaker: 0
      text: You are trapped on the balcony and cannot evacuate, correct?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 1
      extractableSpans: []
    callerLine:
      lineId: confirm_safety_caller
      speaker: 1
      text: Yes, the smoke is too thick inside!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 1
      extractableSpans:
      - displayText: Yes
        normalizedValue: Trapped on balcony
        targetFieldId: CallerSafety
        infoType: CallerSafety
        exactSelection: 1
        hasExtraContext: 0
  followUpQuestionPool:
  - questionId: apt_bed_q_address_exact
    questionText: What is the exact address?
    quality: 0
    relatedFieldId: Address
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_address
    isDistractorQuestion: 0
    authorNote: Primary location-identification question.
  - questionId: apt_bed_q_anyone_inside
    questionText: Is anyone still inside the apartment or on your floor?
    quality: 0
    relatedFieldId: OccupantRisk
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_occupant_risk
    isDistractorQuestion: 0
    authorNote: Critical life-safety follow-up.
  - questionId: apt_bed_q_hazard_elec
    questionText: Do you know how it started? Are there any electrical or gas hazards?
    quality: 0
    relatedFieldId: hazard
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_hazard
    isDistractorQuestion: 0
    authorNote: High-priority hazard-identification question.
  - questionId: apt_bed_q_fire_spread
    questionText: Is the fire spreading out of the bedroom?
    quality: 1
    relatedFieldId: SpreadStatus
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_spread_status
    isDistractorQuestion: 0
    authorNote: Useful but secondary to immediate life-safety questions.
  - questionId: apt_bed_q_caller_safe
    questionText: Are you somewhere safe right now? Can you evacuate?
    quality: 0
    relatedFieldId: CallerSafety
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_caller_safety
    isDistractorQuestion: 0
    authorNote: Critical life-safety for trapped caller.
  - questionId: apt_bed_q_distractor_1
    questionText: Are the sprinklers going off?
    quality: 2
    relatedFieldId: 
    suggestedWhenFieldMissing: 0
    hideIfFieldAlreadyKnown: 0
    linkedStepId: 
    distractorCallerReplyText: We don't have sprinklers in this old building!
    isDistractorQuestion: 1
    authorNote: Lower-priority distractor.
  incidentSeed:
    fireOrigin: Bedroom_GeneralArea
    hazardType: Electrical
    requiresIsolation: 1
    initialFireIntensity: 0.85
    initialFireCount: 2
    fireSpreadPreset: Aggressive
    startSmokeDensity: 0.60
    smokeAccumulationMultiplier: 1.50
    ventilationPreset: Confined
  expectedReport:
    address: 404 River Road, Apt 3B
    fireLocation: Bedroom (3rd Floor)
    occupantRisk: Elderly neighbor trapped
    hazard: Electrical space heater
    spreadStatus: Spreading to hallway
    callerSafety: Trapped on balcony
    severity: High
  assessRisk:
    requiredForAssessRisk:
    - Address
    - fire_location
    recommendedForAssessRisk:
    - OccupantRisk
    - hazard
    - SpreadStatus
    - CallerSafety
    minimumRecommendedCount: 2
    expectedSeverity: High
  resultReview:
    criticalFieldIds:
    - Address
    - fire_location
    - OccupantRisk
    - CallerSafety
    expectedConfirmedFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 8
      issueText: 
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 8
      issueText: 
    correctnessFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 8
      issueText: Address was incorrect or missing.
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 6
      issueText: Fire location was incorrect or missing.
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 8
      issueText: Occupant risk was incomplete.
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 6
      issueText: Hazard information was incomplete.
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 6
      issueText: Spread status was incomplete.
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 8
      issueText: Caller safety information was incomplete.
    readinessFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 4
      issueText: 
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 3
      issueText: 
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 3
      issueText: 
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 3
      issueText: 
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 3
      issueText: 
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 3
      issueText: 
    - fieldId: Severity
      displayName: Severity
      scoreWeight: 2
      issueText: 
    severityCorrectScore: 20
    severityPartialScore: 10
    severityPartialValue: Medium
    followUpOptimalScore: 2
    followUpAcceptableScore: 1
    followUpPoorPenalty: 1
    followUpMaxScore: 8
    followUpGoodThreshold: 4
    followUpMixedThreshold: 1
    targetCallTimeSeconds: 90
    acceptableCallTimeSeconds: 150
    callTimeMaxScore: 4
    strongCorrectnessThreshold: 35
    readySubmissionThreshold: 20
    feedback:
      positiveSeverity: Good risk assessment.
      missingSeverity: Severity assessment was missing.
      incorrectSeverity: Severity was lower than expected for a multi-story entrapment.
      strongFollowUp: You generally prioritized relevant follow-up questions.
      mixedFollowUp: Some follow-up questions were useful, but prioritization was uneven.
      poorFollowUp: Some follow-up questions were lower priority than the situation required.
      allConfirmed: Address and caller safety were confirmed.
      noneConfirmed: No critical facts were confirmed.
      partialConfirmed: More read-back confirmation was needed for critical facts.
      strongCorrectness: Key incident details matched the scenario well.
      readyToSubmit: Report was ready to submit.
      incompleteSubmission: Some report details were missing at submission.