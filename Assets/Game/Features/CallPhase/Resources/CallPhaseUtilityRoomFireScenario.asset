  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f14c3d1b58a44b9a8d668ed8888e3fb4, type: 3}
  m_Name: CallPhaseUtilityRoomFireScenario
  m_EditorClassIdentifier: 
  scenarioId: utility_room_fire
  displayName: Utility Room Fire
  category: Commercial/Apartment Fire
  description: A high-voltage electrical fire in the ground floor utility room of a 6-story building, sending toxic smoke up the stairwell.
  initialTranscriptLines:
  - lineId: intro_operator_open
    speaker: 0
    text: 911, where is your emergency?
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_caller_open
    speaker: 1
    text: I'm the security guard at the complex, we have a major electrical fire!
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_operator_fire_location
    speaker: 0
    text: Where exactly is the fire located?
    isExtractable: 0
    startsAsActiveChunk: 0
    isConfirmationLine: 0
    extractableSpans: []
  - lineId: intro_caller_fire_location
    speaker: 1
    text: It's in the utility room on the ground floor!
    isExtractable: 1
    startsAsActiveChunk: 1
    isConfirmationLine: 0
    extractableSpans:
    - displayText: utility room on the ground floor
      normalizedValue: Utility Room (Ground Floor)
      targetFieldId: fire_location
      infoType: FireLocation
      exactSelection: 1
      hasExtraContext: 0
  followUpSteps:
  - stepId: collect_address
    stepType: 0
    triggerFieldId: fire_location
    triggerValue: Utility Room (Ground Floor)
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_address
      speaker: 0
      text: What is the address of the complex?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_address
      speaker: 1
      text: It's 100 Main Street!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: 100 Main Street
        normalizedValue: 100 Main Street
        targetFieldId: Address
        infoType: Address
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_hazard
    stepType: 0
    triggerFieldId: Address
    triggerValue: 100 Main Street
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_hazard
      speaker: 0
      text: Are there any specific hazards like gas or high voltage?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_hazard
      speaker: 1
      text: It's the high-voltage main electrical panel, and I can't shut off the power!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: high-voltage main electrical panel
        normalizedValue: High-voltage electrical panel
        targetFieldId: hazard
        infoType: Hazard
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_spread_status
    stepType: 0
    triggerFieldId: hazard
    triggerValue: High-voltage electrical panel
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_spread_status
      speaker: 0
      text: Is the fire spreading out of the utility room?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_spread_status
      speaker: 1
      text: The flames aren't, but thick black smoke is filling the stairwell fast!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: thick black smoke is filling the stairwell
        normalizedValue: Smoke in stairwell
        targetFieldId: SpreadStatus
        infoType: SpreadStatus
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_occupant_risk
    stepType: 0
    triggerFieldId: SpreadStatus
    triggerValue: Smoke in stairwell
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_occupant_risk
      speaker: 0
      text: Are there people still inside the building?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_occupant_risk
      speaker: 1
      text: Yes, there are people trapped on the upper floors because of the smoke!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: people trapped on the upper floors
        normalizedValue: People trapped on upper floors
        targetFieldId: OccupantRisk
        infoType: OccupantRisk
        exactSelection: 1
        hasExtraContext: 0
  - stepId: collect_caller_safety
    stepType: 0
    triggerFieldId: OccupantRisk
    triggerValue: People trapped on upper floors
    confirmationFieldId: 
    expectedConfirmedValue: 
    operatorLine:
      lineId: ask_caller_safety
      speaker: 0
      text: Are you in a safe location right now?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_caller_safety
      speaker: 1
      text: I evacuated and I'm outside the building now!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 0
      extractableSpans:
      - displayText: outside the building now
        normalizedValue: Outside building
        targetFieldId: CallerSafety
        infoType: CallerSafety
        exactSelection: 1
        hasExtraContext: 0
  - stepId: confirm_hazard
    stepType: 1
    triggerFieldId: CallerSafety
    triggerValue: Outside building
    confirmationFieldId: hazard
    expectedConfirmedValue: High-voltage electrical panel
    operatorLine:
      lineId: confirm_hazard_operator
      speaker: 0
      text: Let me confirm, this is a high-voltage electrical fire and power is still ON?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 1
      extractableSpans: []
    callerLine:
      lineId: confirm_hazard_caller
      speaker: 1
      text: Yes, that's correct. Be careful!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 1
      extractableSpans:
      - displayText: Yes, that's correct.
        normalizedValue: High-voltage electrical panel
        targetFieldId: hazard
        infoType: Hazard
        exactSelection: 1
        hasExtraContext: 0
  - stepId: confirm_address
    stepType: 1
    triggerFieldId: hazard
    triggerValue: High-voltage electrical panel
    confirmationFieldId: Address
    expectedConfirmedValue: 100 Main Street
    operatorLine:
      lineId: confirm_address_operator
      speaker: 0
      text: And the address is 100 Main Street?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 1
      extractableSpans: []
    callerLine:
      lineId: confirm_address_caller
      speaker: 1
      text: Yes, 100 Main Street!
      isExtractable: 1
      startsAsActiveChunk: 1
      isConfirmationLine: 1
      extractableSpans:
      - displayText: Yes
        normalizedValue: 100 Main Street
        targetFieldId: Address
        infoType: Address
        exactSelection: 1
        hasExtraContext: 0
  followUpQuestionPool:
  - questionId: utility_q_address_exact
    questionText: What is the exact address of the complex?
    quality: 0
    relatedFieldId: Address
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_address
    isDistractorQuestion: 0
    authorNote: Primary location-identification question.
  - questionId: utility_q_anyone_inside
    questionText: Are there people still inside the building?
    quality: 0
    relatedFieldId: OccupantRisk
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_occupant_risk
    isDistractorQuestion: 0
    authorNote: Critical life-safety follow-up for high-rise.
  - questionId: utility_q_hazard_elec
    questionText: Are there any specific hazards like gas or high voltage?
    quality: 0
    relatedFieldId: hazard
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_hazard
    isDistractorQuestion: 0
    authorNote: Extremely critical for utility room fires.
  - questionId: utility_q_fire_spread
    questionText: Is the fire spreading out of the utility room?
    quality: 0
    relatedFieldId: SpreadStatus
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_spread_status
    isDistractorQuestion: 0
    authorNote: Crucial to know if stairwells are compromised.
  - questionId: utility_q_caller_safe
    questionText: Are you in a safe location right now?
    quality: 1
    relatedFieldId: CallerSafety
    suggestedWhenFieldMissing: 1
    hideIfFieldAlreadyKnown: 1
    linkedStepId: collect_caller_safety
    isDistractorQuestion: 0
    authorNote: Standard safety check.
  - questionId: utility_q_distractor_1
    questionText: Did you try using a fire extinguisher?
    quality: 2
    relatedFieldId: 
    suggestedWhenFieldMissing: 0
    hideIfFieldAlreadyKnown: 0
    linkedStepId: 
    distractorCallerReplyText: No, it's high voltage, I wasn't going to touch it!
    isDistractorQuestion: 1
    authorNote: Lower-priority distractor.
  incidentSeed:
    fireOrigin: UtilityRoom_Panel
    hazardType: Electrical
    requiresIsolation: 1
    initialFireIntensity: 0.90
    initialFireCount: 1
    fireSpreadPreset: Moderate
    startSmokeDensity: 0.90
    smokeAccumulationMultiplier: 2.00
    ventilationPreset: StairwellChimney
  actualVictimCount: 4
  dispatchEstimatedVictimCountKnown: 1
  dispatchEstimatedVictimCountMin: 2
  dispatchEstimatedVictimCountMax: 6
  expectedReport:
    address: 100 Main Street
    fireLocation: Utility Room (Ground Floor)
    occupantRisk: People trapped on upper floors
    hazard: High-voltage electrical panel
    spreadStatus: Smoke in stairwell
    callerSafety: Outside building
    severity: High
  assessRisk:
    requiredForAssessRisk:
    - Address
    - fire_location
    - hazard
    recommendedForAssessRisk:
    - OccupantRisk
    - SpreadStatus
    - CallerSafety
    minimumRecommendedCount: 2
    expectedSeverity: High
  resultReview:
    criticalFieldIds:
    - Address
    - fire_location
    - hazard
    - OccupantRisk
    expectedConfirmedFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 6
      issueText: 
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 8
      issueText: 
    correctnessFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 8
      issueText: Address was incorrect or missing.
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 6
      issueText: Fire location was incorrect or missing.
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 8
      issueText: Occupant risk was incomplete.
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 8
      issueText: Hazard information was incorrect or missing.
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 8
      issueText: Spread status was incomplete.
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 4
      issueText: Caller safety information was incomplete.
    readinessFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 4
      issueText: 
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 3
      issueText: 
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 3
      issueText: 
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 4
      issueText: 
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 3
      issueText: 
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 1
      issueText: 
    - fieldId: Severity
      displayName: Severity
      scoreWeight: 2
      issueText: 
    severityCorrectScore: 20
    severityPartialScore: 10
    severityPartialValue: Medium
    followUpOptimalScore: 2
    followUpAcceptableScore: 1
    followUpPoorPenalty: 1
    followUpMaxScore: 8
    followUpGoodThreshold: 4
    followUpMixedThreshold: 1
    targetCallTimeSeconds: 90
    acceptableCallTimeSeconds: 150
    callTimeMaxScore: 4
    strongCorrectnessThreshold: 38
    readySubmissionThreshold: 18
    feedback:
      positiveSeverity: Good risk assessment.
      missingSeverity: Severity assessment was missing.
      incorrectSeverity: Severity was lower than expected for a high-voltage stairwell emergency.
      strongFollowUp: You correctly prioritized the electrical hazard and smoke spread.
      mixedFollowUp: Some follow-up questions were useful, but prioritization was uneven.
      poorFollowUp: Critical questions about the electrical hazard or trapped occupants were missed.
      allConfirmed: Address and hazard were confirmed.
      noneConfirmed: No critical facts were confirmed.
      partialConfirmed: More read-back confirmation was needed for the high-voltage hazard.
      strongCorrectness: Key incident details matched the scenario well.
      readyToSubmit: Report was ready to submit.
      incompleteSubmission: Some report details were missing at submission.
