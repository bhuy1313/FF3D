    recommendedForAssessRisk:
    - OccupantRisk
    - hazard
    - SpreadStatus
    - CallerSafety
    minimumRecommendedCount: 1
    expectedSeverity: High
  resultReview:
    correctnessFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 8
      issueText: Address was incorrect or missing.
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 6
      issueText: Fire location was incorrect or missing.
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 8
      issueText: Occupant risk was incomplete.
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 6
      issueText: Hazard information was incomplete.
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 6
      issueText: Spread status was incomplete.
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 6
      issueText: Caller safety information was incomplete.
    criticalFieldIds:
    - Address
    - fire_location
    - OccupantRisk
    expectedConfirmedFields:
    - fieldId: Address
      displayName: Address
      scoreWeight: 8
      issueText: 
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 6
      issueText: 
    - fieldId: CallerSafety
      displayName: Caller Safety
      scoreWeight: 6
      issueText: 
