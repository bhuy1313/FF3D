      scoreWeight: 4
      issueText: 
    - fieldId: fire_location
      displayName: Fire Location
      scoreWeight: 3
      issueText: 
    - fieldId: OccupantRisk
      displayName: Occupant Risk
      scoreWeight: 3
      issueText: 
    - fieldId: hazard
      displayName: Hazard
      scoreWeight: 3
      issueText: 
    - fieldId: SpreadStatus
      displayName: Spread Status
      scoreWeight: 3
      issueText: 
