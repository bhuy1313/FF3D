      lineId: ask_hazard
      speaker: 0
      text: Do you know how it started? Are there any gas cylinders nearby?
      isExtractable: 0
      startsAsActiveChunk: 0
      isConfirmationLine: 0
      extractableSpans: []
    callerLine:
      lineId: reply_hazard
      speaker: 1
